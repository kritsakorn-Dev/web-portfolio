---
---

<section id="about" class="py-32 relative">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left side: Image/Visual -->
      <div class="reveal">
        <div class="relative">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden glass p-1 tilt-card">
            <div class="w-full h-full rounded-[20px] bg-gradient-to-br from-accent/20 via-purple-500/10 to-surface flex items-center justify-center">
              <div class="text-center">
                <div class="text-8xl md:text-9xl font-display font-bold gradient-text mb-4">K</div>
                <div class="text-muted text-sm uppercase tracking-[0.3em]">Full-stack Developer</div>
              </div>
            </div>
          </div>
          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 px-4 py-2 rounded-xl glass animate-bounce" style="animation-duration: 3s">
            <span class="text-2xl">🚀</span>
          </div>
          <div class="absolute -bottom-4 -left-4 px-4 py-2 rounded-xl glass animate-bounce" style="animation-duration: 4s; animation-delay: 1s">
            <span class="text-2xl">💻</span>
          </div>
        </div>
      </div>

      <!-- Right side: Content -->
      <div>
        <div class="reveal">
          <span class="text-accent font-medium text-sm uppercase tracking-[0.2em]">About Me</span>
          <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl mt-4 mb-8 leading-snug">
            Crafting digital<br />
            <span class="gradient-text">experiences</span> that matter
          </h2>
        </div>

        <div class="space-y-6 reveal reveal-delay-1">
          <p class="text-muted text-lg leading-relaxed">
            I'm Kritsakorn Payakmareong, a dedicated Full-stack Developer with a passion for building 
            clean, efficient, and user-centric web applications. I believe in writing code that not 
            only works but tells a story.
          </p>
          <p class="text-muted text-lg leading-relaxed">
            Currently, I'm sharpening my skills through an internship at 
            <span class="text-light font-medium">Baycoms</span>, where I work on real-world 
            projects while pursuing my degree at 
            <span class="text-light font-medium">Rangsit University</span>.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-12 reveal reveal-delay-2">
          <div class="text-center md:text-left">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text" data-target="10" data-suffix="+">0+</div>
            <div class="text-muted text-sm mt-1">Projects Built</div>
          </div>
          <div class="text-center md:text-left">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text" data-target="5" data-suffix="+">0+</div>
            <div class="text-muted text-sm mt-1">Technologies</div>
          </div>
          <div class="text-center md:text-left">
            <div class="text-3xl md:text-4xl font-display font-bold gradient-text" data-target="1" data-suffix="+">0+</div>
            <div class="text-muted text-sm mt-1">Years Learning</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
