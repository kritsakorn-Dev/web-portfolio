---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background gradient orbs — GPU-isolated to avoid blocking main thread paint -->
  <div class="absolute top-1/4 -left-20 w-64 h-64 md:w-96 md:h-96 md:-left-32 bg-accent/10 rounded-full blur-[128px] animate-pulse" style="will-change:transform;transform:translateZ(0);contain:paint;"></div>
  <div class="absolute bottom-1/4 -right-20 w-64 h-64 md:w-96 md:h-96 md:-right-32 bg-purple-500/10 rounded-full blur-[128px] animate-pulse" style="will-change:transform;transform:translateZ(0);contain:paint;animation-delay:2s;"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 grid-pattern"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 text-center">
    <!-- Status badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="text-sm text-muted">Available for opportunities</span>
    </div>

    <!-- Main heading -->
    <h1 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-[1.05] tracking-tight mb-8">
      <span class="block animate-slide-up" style="animation-delay: 0.1s">Hi, I'm</span>
      <span class="block gradient-text animate-slide-up scramble" style="animation-delay: 0.25s">Kritsakorn</span>
      <span class="block text-muted/60 animate-slide-up" style="animation-delay: 0.4s">Payakmareong</span>
    </h1>

    <!-- Subtitle -->
    <p class="max-w-2xl mx-auto text-base md:text-xl text-muted leading-relaxed mb-8 md:mb-12 animate-slide-up" style="animation-delay: 0.55s">
      A passionate <span class="text-light font-medium">Full-stack Developer</span> crafting 
      modern web experiences. Currently interning at 
      <span class="text-accent font-medium">Baycoms</span> and studying at 
      <span class="text-light font-medium">Rangsit University</span>.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-slide-up relative z-20" style="animation-delay: 0.7s">
      <a
        href="#projects"
        class="magnetic group inline-flex items-center gap-2 sm:gap-3 px-6 py-3 sm:px-8 sm:py-4 rounded-full bg-accent text-[#0a0a0a] font-medium text-base sm:text-lg hover:bg-accent-light transition-all duration-300 hover:shadow-[0_0_40px_rgba(200,255,0,0.3)]"
      >
        View My Work
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
      <a
        href="#contact"
        class="magnetic inline-flex items-center gap-2 sm:gap-3 px-6 py-3 sm:px-8 sm:py-4 rounded-full bg-dark border border-contrast/10 text-light font-medium text-base sm:text-lg hover:border-accent/50 hover:text-accent transition-all duration-300"
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>
