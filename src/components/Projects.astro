---
const projects = [
  {
    title: 'E-Commerce Platform',
    description: 'A full-featured online store with cart, checkout, and payment integration. Built with modern technologies for optimal performance.',
    tags: ['React', 'Node.js', 'MongoDB', 'Stripe'],
    image: 'from-violet-500/20 to-purple-900/20',
    year: '2025',
    link: '#',
  },
  {
    title: 'Task Management App',
    description: 'A collaborative project management tool with real-time updates, drag-and-drop boards, and team features.',
    tags: ['Next.js', 'TypeScript', 'PostgreSQL', 'Socket.io'],
    image: 'from-blue-500/20 to-cyan-900/20',
    year: '2025',
    link: '#',
  },
  {
    title: 'Social Media Dashboard',
    description: 'An analytics dashboard for social media managers with charts, scheduling, and content management.',
    tags: ['Vue.js', 'Express', 'Firebase', 'Chart.js'],
    image: 'from-emerald-500/20 to-teal-900/20',
    year: '2024',
    link: '#',
  },
  {
    title: 'AI Chat Application',
    description: 'An intelligent chatbot application powered by AI with natural language processing and contextual responses.',
    tags: ['React', 'Python', 'OpenAI', 'TailwindCSS'],
    image: 'from-amber-500/20 to-orange-900/20',
    year: '2024',
    link: '#',
  },
];
---

<section id="projects" class="py-32 relative">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 reveal">
      <div>
        <span class="text-accent font-medium text-sm uppercase tracking-[0.2em]">Selected Work</span>
        <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl mt-4 leading-tight">
          Take a look at<br />my <span class="gradient-text">projects</span>
        </h2>
      </div>
      <p class="text-muted text-lg mt-4 md:mt-0 max-w-md">
        A collection of projects that showcase my skills and passion for development.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <a
          href={project.link}
          class={`reveal reveal-delay-${(i % 4) + 1} group block rounded-3xl overflow-hidden glass card-hover tilt-card`}
        >
          <!-- Project Image/Preview -->
          <div class={`aspect-video bg-gradient-to-br ${project.image} relative overflow-hidden`}>
            <div class="absolute inset-0 grid-pattern-sm"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
              </div>
            </div>
            <!-- Year badge -->
            <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm text-xs text-white/70">
              {project.year}
            </div>
          </div>

          <!-- Project Info -->
          <div class="p-8">
            <h3 class="font-display font-semibold text-2xl text-light group-hover:text-accent transition-colors duration-300 mb-3">
              {project.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed mb-6">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-medium text-accent bg-accent/10 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- View All CTA -->
    <div class="text-center mt-16 reveal">
      <a
        href="https://github.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="magnetic inline-flex items-center gap-3 px-8 py-4 rounded-full bg-dark border border-contrast/10 text-light font-medium hover:border-accent/50 hover:text-accent transition-all duration-300"
      >
        View All on GitHub
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
      </a>
    </div>
  </div>
</section>
